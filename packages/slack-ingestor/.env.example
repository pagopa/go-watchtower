# ─── Slack ───────────────────────────────────────────────────────────────────
# Bot token con scope: channels:history, groups:history, channels:read
SLACK_BOT_TOKEN=xoxb-your-token-here

# ─── Database ─────────────────────────────────────────────────────────────────
# Stringa di connessione PostgreSQL locale (stessa del backend)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/go_watchtower

# ─── Debug ────────────────────────────────────────────────────────────────────
# Imposta a 1 per attivare il log messaggio-per-messaggio con esito del parser
# VERBOSE=1
