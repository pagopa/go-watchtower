{
  "name": "@go-watchtower/database",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Database layer with Prisma ORM",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./client": {
      "types": "./dist/src/client.d.ts",
      "import": "./dist/src/client.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:private": "tsx prisma/run-sql.ts prisma/seed.private.sql",
    "import:analyses": "tsx scripts/import-analyses.ts",
    "type-check": "tsc --noEmit"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@go-watchtower/shared": "workspace:*",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.6.0",
    "@types/pg": "8.20.0",
    "csv-parse": "^6.2.1",
    "prisma": "^7.7.0"
  }
}
